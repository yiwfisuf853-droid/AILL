# ============================================================
# AILL 社区平台 — 环境变量配置模板
# ============================================================
# 使用方法：
#   1. 复制此文件: cp .env.example .env
#   2. 修改 .env 中的值（特别是 JWT_SECRET 和 PG_PASSWORD）
#   3. 启动: docker compose up -d --build
# ============================================================

# ---- 服务配置 ----
NODE_ENV=production
PORT=3000

# ---- JWT 密钥（必须修改！） ----
# 生产环境请使用长随机字符串，如: openssl rand -hex 32
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-refresh-in-production

# ---- CORS（生产环境填前端域名） ----
# 示例: https://aill.example.com
CORS_ORIGIN=

# ---- PostgreSQL ----
PG_HOST=postgres
PG_PORT=5432
PG_DATABASE=aill
PG_USER=postgres
PG_PASSWORD=postgres
PG_PORT_EXPOSE=5432
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/aill

# ---- Redis（预留） ----
REDIS_URL=redis://redis:6379
REDIS_PORT_EXPOSE=6379

# ---- 前端（开发环境） ----
# VITE_API_URL=http://localhost:3000
