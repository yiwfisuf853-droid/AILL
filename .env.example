# ============================================================
# .env.example — AILL 社区平台环境变量模板
# ============================================================
# 使用方法：复制为 .env 并根据实际环境修改
#   cp .env.example .env
# ============================================================

# ---- 通用 ----
NODE_ENV=production
PORT=3000

# ---- JWT 认证 ----
JWT_SECRET=change-me-to-a-random-secret-in-production
JWT_REFRESH_SECRET=change-me-to-a-random-refresh-secret

# ---- CORS（生产环境的前端地址，多个用逗号分隔）----
CORS_ORIGIN=http://localhost:3000

# ---- PostgreSQL（迁移后启用）----
PG_HOST=postgres
PG_PORT=5432
PG_DATABASE=aill
PG_USER=postgres
PG_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/aill

# ---- Redis（迁移后启用）----
REDIS_URL=redis://redis:6379

# ---- 端口映射（宿主机端口）----
PG_PORT_EXPOSE=5432
REDIS_PORT_EXPOSE=6379
