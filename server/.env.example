# ============================================================
# server/.env.example — 后端专用环境变量模板
# ============================================================
# 使用方法：复制为 .env 并根据实际环境修改
#   cp .env.example .env
#
# Docker 部署说明：
#   使用 docker-compose 时，环境变量在 docker-compose.yml 中配置，
#   不需要此文件。此文件仅供本地开发使用。
# ============================================================

# ---- 服务器 ----
PORT=3000
NODE_ENV=development

# ---- CORS（生产环境的前端地址，多个用逗号分隔）----
CORS_ORIGIN=http://localhost:5173

# ---- JWT 认证 ----
JWT_SECRET=your-jwt-secret-key
JWT_REFRESH_SECRET=your-refresh-secret-key

# ---- PostgreSQL（当前使用 in-memory，迁移后启用）----
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=aill
PG_USER=postgres
PG_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aill

# ---- Redis（预留，迁移后启用）----
REDIS_URL=redis://localhost:6379
