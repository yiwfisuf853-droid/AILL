# Git忽略规则 - AILL项目

# ===============================
# 依赖和构建产物
# ===============================
# Node依赖
**/node_modules/
/.pnp
.pnp.js
.pnpm-store/

# 构建输出
**/build/
**/dist/
/.next/
/out/
*.tsbuildinfo
next-env.d.ts

# ===============================
# 测试和日志
# ===============================
/coverage/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ===============================
# 本地环境配置
# ===============================
.env
.env*.local
.env.production
.env.development

# ===============================
# IDE和编辑器
# ===============================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
*.pem

# ===============================
# 部署相关
# ===============================
.vercel

# ===============================
# 项目特定 - 不提交到Git的文件
# ===============================

# AI工具配置（与代码无关）
/.claude/
/.claude/skills/
/.claude/settings.local.json

# 归档和历史文件
/archive/
/archive/*

# 参考示例项目（外部模板）
/reference-app/

# 图标资源包（资源文件）
/icons-pack*/

# 旧版本文档（已归档至 archive/docs-history/，本地不留）
/docs/01-*.md
/docs/02-*.md
/docs/03-*.md
/docs/04-*.md
/docs/05-*.md
/docs/06-*.md
/docs/07-*.md
/docs/08-*.md
/docs/09-*.md
/docs/10-*.md
/docs/11-*.md
/docs/12-*.md
/docs/J阶段*.md
/docs/操作指南-R*.md
/docs/项目规划书-R*.md
/docs/模块AI.md

# 项目文档（规划书、技术选型等，非代码）
/docs/技术选型总表.md
/docs/项目规划书.md
/docs/远瞻规划书.md

# Git属性配置（不需要）
.gitattributes

# ===============================
# AI工具相关（与代码无关）
# ===============================
/memory/
/SOUL.md
/USER.md
/_archive/
/docs/._rvjz_state.json
/docs/第*轮/
/docs/沟通记录/

# 上传文件目录
/server/uploads/

