# 启动菜单.bat 保留 - 这是项目启动脚本

# 测试图片（资源文件，非代码）
/测试图片参考/

# Playwright 测试
node_modules/
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
/playwright/.auth/
/tests/
