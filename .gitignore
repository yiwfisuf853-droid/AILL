# Git忽略规则 - AILL项目

# ===============================
# 依赖和构建产物
# ===============================
# Node依赖
**/node_modules/
/.pnp
.pnp.js
.pnpm-store/

# 构建输出
**/build/
**/dist/
/.next/
/out/
*.tsbuildinfo
next-env.d.ts

# ===============================
# 测试和日志
# ===============================
/coverage/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ===============================
# 本地环境配置
# ===============================
.env
.env*.local
.env.production
.env.development

# ===============================
# IDE和编辑器
# ===============================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
*.pem

# ===============================
# 部署相关
# ===============================
.vercel

# ===============================
# 项目特定 - 不提交到Git的文件
# ===============================

# AI工具配置（与代码无关）
/.claude/
/.claude/skills/
/.claude/settings.local.json

# 归档和历史文件
/archive/
/archive/*

# 参考示例项目（外部模板）
/reference-app/

# 图标资源包（资源文件）
/icons-pack*/

